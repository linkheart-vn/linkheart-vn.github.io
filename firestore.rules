rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email_verified == true && 
         (request.auth.token.email == "dauphu205712@gmail.com" || request.auth.token.email == "daup4531@gmail.com"))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                    incoming().keys().hasAll(['uid', 'email']) &&
                    incoming().uid == userId;
      allow update: if (isOwner(userId) || isAdmin()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'walletBalance', 'rating', 'totalTrips', 'pin', 'failedAttempts', 'lockoutUntil', 'preferredMode', 'cards', 'activePlanId', 'trialDaysLeft']);

      match /requests/{requestId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
      match /status/elderly {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
      match /reminders/{reminderId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /memories/{memoryId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
      }
      match /logs/{logId} {
        allow read, create: if isOwner(userId) || isAdmin();
      }
      match /appointments/{appointmentId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /acceptedHelp/{helpId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /reviews/{reviewId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
      }
    }

    match /helpRequests/{requestId} {
      allow list: if isSignedIn() && resource.data.status == 'open';
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() && 
                    isValidId(requestId) &&
                    incoming().keys().hasAll(['userId', 'userName', 'service', 'status', 'createdAt']) &&
                    incoming().userId == request.auth.uid &&
                    incoming().status == 'open' &&
                    incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && (
                      (existing().userId == request.auth.uid && incoming().userId == request.auth.uid) ||
                      (existing().status == 'open' && 
                       incoming().status == 'matched' && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
                      isAdmin()
                    );
      
      allow delete: if (existing().userId == request.auth.uid) || isAdmin();
    }

    match /companions/{companionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
